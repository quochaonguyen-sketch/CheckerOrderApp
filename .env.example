# Google service account email, for example:
# warehouse-scanner@your-project-id.iam.gserviceaccount.com
GOOGLE_CLIENT_EMAIL=

# Private key from the service account JSON.
# Keep escaped newlines as \n when storing in Vercel or .env.local.
# The server utility will convert escaped \n into real newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Sheet ID from the spreadsheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART_IS_THE_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Sheet tab name, for example: Orders
GOOGLE_SHEETS_SHEET_NAME=Orders

# Optional cache TTL in milliseconds to reduce Google API calls during fast scanning.
GOOGLE_SHEETS_CACHE_TTL_MS=10000
